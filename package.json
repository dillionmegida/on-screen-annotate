{
  "name": "screenink",
  "version": "1.0.0",
  "description": "Transparent screen annotation overlay for macOS",
  "author": "ScreenInk",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "build-dmg": "electron-builder --mac dmg"
  },
  "build": {
    "appId": "com.screenink.app",
    "productName": "ScreenInk",
    "mac": {
      "category": "public.app-category.utilities",
      "target": ["dmg"]
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}